# Copy to .env.deploy (gitignored). chmod 600.

# Iran app server
SSH_HOST=45.90.73.12
SSH_PORT=2212
SSH_USER=root
SSH_KEY_PATH=C:/Users/Usher/.ssh/id_ed25519
REMOTE_DIR=/opt/xilo

# Germany proxy (native, no Docker)
DE_SSH_HOST=95.217.205.246
DE_SSH_PORT=2385
DE_SSH_USER=root
DE_SSH_KEY_PATH=C:/Users/Usher/.ssh/id_ed25519

# transfer = build on this PC, docker save|load to Iran (default, lowest VPS traffic)
# remote   = build on Iran (expensive; only if local Docker unavailable)
BUILD_MODE=transfer

# Optional: pin tag; otherwise content-hash deploy-<git>-<hash>
# XILO_IMAGE_TAG=latest

# Optional: limit which app services sync (api,web)
# DEPLOY_SERVICES=api,web

NEXT_PUBLIC_API_URL=https://brain.aile.ir
NEXT_PUBLIC_WS_URL=wss://brain.aile.ir
NEXT_PUBLIC_URL=https://aile.ir

PROXY_HOST=learn.xilo.ir
