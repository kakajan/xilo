# Runtime-only image — binary is built elsewhere when Iran cannot reach Go module proxies.
FROM alpine:3.21
RUN apk add --no-cache ca-certificates && adduser -D -u 1000 xilo
WORKDIR /app
COPY api-gateway /api-gateway
RUN chmod 755 /api-gateway && chown xilo:xilo /api-gateway
USER xilo
EXPOSE 8000
ENV PORT=8000
ENTRYPOINT ["/api-gateway"]
